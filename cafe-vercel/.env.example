# ============================================================
# Environment Variables — copy this file to .env and fill in
# ============================================================

# PostgreSQL connection string (required)
# Example: postgresql://user:password@host:5432/dbname
DATABASE_URL=

# Admin password for /admin area (required)
ADMIN_PASSWORD=admin123

# Cloudinary credentials for image upload (required for menu photo uploads)
# Create a free account at https://cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_UPLOAD_FOLDER=cafe-menus
